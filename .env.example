# === 应用 ===
APP_SECRET=your-jwt-secret-change-me
APP_ENV=development
ENCRYPTION_KEY=your-32-byte-aes256-encryption-key

# === 存储 ===
MONGODB_URI=mongodb://root:social_tool_dev@localhost:27017/social_tool?authSource=admin
REDIS_URI=redis://:social_tool_dev@localhost:6379/0

# === Twitter（MVP 登录 + 平台连接） ===
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
# 与前端访问地址一致；若用 localhost 打开页面，请改为 http://localhost:5173/auth/twitter/callback 并在 X 后台同时登记
TWITTER_CALLBACK_URL=http://127.0.0.1:5173/auth/twitter/callback

# === LLM ===
KIMI_API_KEY=your-kimi-api-key
CLAUDE_API_KEY=your-claude-api-key

# === Google（预留） ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === 小红书（预留） ===
# XHS_APP_KEY=
# XHS_APP_SECRET=

# === TikTok（预留） ===
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# === 调度 ===
POLL_INTERVAL_MINUTES=10
FEED_POLL_INTERVAL_MINUTES=5
